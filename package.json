{
  "name": "checkout-team-logger",
  "version": "1.0.0",
  "description": "Team logger is used to keep aligned our team and their valuable time.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "electron": "electron electron/main.js",
    "dev:desktop": "concurrently \"npm run dev\" \"npm run electron\"",
    "build:frontend": "npm run build --prefix frontend",
    "build:desktop": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "form-data": "^4.0.5",
    "screenshot-desktop": "^1.15.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.teamlogger.app",
    "productName": "Team Logger",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}